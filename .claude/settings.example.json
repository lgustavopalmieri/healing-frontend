{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Template — rode `scripts/init-claude.js` (ou substitua $PWD manualmente pelo caminho absoluto do projeto) e salve como settings.local.json. Veja aula 10 do curso sobre o porquê de usarmos $PWD aqui.",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git switch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git rev-parse:*)",
      "mcp__github",
      "Bash(jira issue:*)",
      "Bash(jira me)",
      "Bash(npm test:*)",
      "Bash(pnpm test:*)",
      "Bash(yarn test:*)",
      "Bash(pytest:*)",
      "Bash(go test:*)",
      "Bash(cargo test:*)",
      "mcp__atlassian"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$PWD/.claude/hooks/validate-commit-message.sh" },
          { "type": "command", "command": "$PWD/.claude/hooks/block-direct-main-commit.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "$PWD/.claude/hooks/post-edit-format.sh" }
        ]
      }
    ]
  }
}
