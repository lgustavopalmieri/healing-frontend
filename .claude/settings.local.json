{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git switch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git rev-parse:*)",
      "mcp__github",
      "Bash(jira issue:*)",
      "Bash(jira me)",
      "Bash(npm test:*)",
      "Bash(pnpm test:*)",
      "Bash(yarn test:*)",
      "Bash(pytest:*)",
      "Bash(go test:*)",
      "Bash(cargo test:*)",
      "mcp__atlassian",
      "Bash(xargs ls -la)",
      "Bash(pnpm typecheck *)",
      "Bash(pnpm lint *)",
      "Bash(git stash *)",
      "Bash(pnpm test:run)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/lgustavopalmieri/healing/healing-frontend/.claude/hooks/validate-commit-message.sh"
          },
          {
            "type": "command",
            "command": "/home/lgustavopalmieri/healing/healing-frontend/.claude/hooks/block-direct-main-commit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/lgustavopalmieri/healing/healing-frontend/.claude/hooks/post-edit-format.sh"
          }
        ]
      }
    ]
  },
  "_comment": "Template — rode `scripts/init-claude.js` (ou substitua /home/lgustavopalmieri/healing/healing-frontend manualmente pelo caminho absoluto do projeto) e salve como settings.local.json. Veja aula 10 do curso sobre o porquê de usarmos /home/lgustavopalmieri/healing/healing-frontend aqui."
}
